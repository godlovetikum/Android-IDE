// android-ide/ui/components/dialogs.slint
//
// NewProjectDialog and OpenProjectDialog — modal overlay components.

import { Button, LineEdit, ComboBox, ScrollView } from "std-widgets.slint";

// ---------------------------------------------------------------------------
// Shared dialog container
// ---------------------------------------------------------------------------

component ModalOverlay inherits Rectangle {
    background: #000000aa;
    width: 100%; height: 100%;
}

// ---------------------------------------------------------------------------
// New Project Dialog (task 014)
// ---------------------------------------------------------------------------

export struct NewProjectRequest {
    name: string,
    path: string,
    project-type: string,
}

export component NewProjectDialog inherits ModalOverlay {
    // Outbound events
    callback confirmed(NewProjectRequest);
    callback cancelled();

    // Internal state
    in-out property <string> project-name: "";
    in-out property <string> project-path: "";
    in-out property <int> selected-type-index: 0;

    // Project type options exposed to Rust so it can build the combo items
    in property <[string]> project-types: ["Rust", "Kotlin (Android)", "Python", "C/C++", "Generic"];

    // Validation: name must be non-empty and contain only safe characters
    pure function name-valid() -> bool {
        project-name.character-count > 0
    }

    // Center card
    Rectangle {
        width: min(parent.width * 0.92, 420px);
        height: card-layout.preferred-height + 32px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: #252526;
        border-radius: 8px;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000080;

        VerticalLayout {
            y: 16px; x: 24px;
            width: parent.width - 48px;
            spacing: 16px;

            card-layout := VerticalLayout {
                spacing: 20px;
                padding-bottom: 8px;

                // Title
                Text {
                    text: "New Project";
                    font-size: 18px;
                    font-weight: 600;
                    color: #cccccc;
                }

                // Project name field
                VerticalLayout {
                    spacing: 6px;
                    Text { text: "Project Name"; font-size: 12px; color: #999999; }
                    name-field := LineEdit {
                        placeholder-text: "my-project";
                        text <=> project-name;
                        font-size: 14px;
                    }
                }

                // Location field
                VerticalLayout {
                    spacing: 6px;
                    Text { text: "Location"; font-size: 12px; color: #999999; }
                    HorizontalLayout {
                        spacing: 8px;
                        path-field := LineEdit {
                            placeholder-text: "/storage/emulated/0";
                            text <=> project-path;
                            font-size: 14px;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "Browse…";
                            width: 80px;
                            // The host Activity handles the SAF picker intent;
                            // it sets project-path via the Rust callback.
                            clicked => { browse-requested(); }
                        }
                    }
                }

                // Project type
                VerticalLayout {
                    spacing: 6px;
                    Text { text: "Project Type"; font-size: 12px; color: #999999; }
                    ComboBox {
                        model: project-types;
                        current-index <=> selected-type-index;
                    }
                }

                // Action buttons
                HorizontalLayout {
                    spacing: 12px;
                    horizontal-stretch: 1;
                    alignment: end;

                    Button {
                        text: "Cancel";
                        clicked => { root.cancelled(); }
                    }
                    Button {
                        text: "Create";
                        primary: true;
                        enabled: root.name-valid();
                        clicked => {
                            root.confirmed(NewProjectRequest {
                                name: project-name,
                                path: project-path,
                                project-type: project-types[selected-type-index],
                            });
                        }
                    }
                }
            }
        }
    }

    // Exposed so Rust can trigger SAF picker
    callback browse-requested();
}

// ---------------------------------------------------------------------------
// Open Project / Recent Projects Dialog (task 015)
// ---------------------------------------------------------------------------

export struct RecentProject {
    name: string,
    path: string,
    last-opened: string,  // ISO date string e.g. "2026-06-10"
}

export component OpenProjectDialog inherits ModalOverlay {
    callback project-selected(string);  // path of the selected project
    callback browse-requested();        // user wants to pick a dir via SAF
    callback cancelled();

    in property <[RecentProject]> recent-projects;

    // Center card
    Rectangle {
        width: min(parent.width * 0.95, 460px);
        height: min(parent.height * 0.75, 520px);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: #252526;
        border-radius: 8px;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000080;

        VerticalLayout {
            padding: 24px;
            spacing: 16px;

            // Title
            Text {
                text: "Open Project";
                font-size: 18px;
                font-weight: 600;
                color: #cccccc;
            }

            // Recent section header
            Text {
                text: recent-projects.length > 0 ? "Recent Projects" : "No recent projects";
                font-size: 12px;
                color: #999999;
            }

            // Recent projects list
            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 2px;
                    for proj in recent-projects : recent-row := Rectangle {
                        height: 56px;
                        border-radius: 4px;
                        background: recent-row-touch.has-hover ? #2d2d2d : transparent;

                        recent-row-touch := TouchArea {
                            clicked => { root.project-selected(proj.path); }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            alignment: center;
                            spacing: 0;

                            // Folder icon (Unicode)
                            Text {
                                text: "📁";
                                font-size: 20px;
                                width: 32px;
                            }

                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Text {
                                    text: proj.name;
                                    font-size: 14px;
                                    color: #cccccc;
                                    overflow: elide;
                                }
                                Text {
                                    text: proj.path;
                                    font-size: 11px;
                                    color: #666666;
                                    overflow: elide;
                                }
                            }

                            Text {
                                text: proj.last-opened;
                                font-size: 11px;
                                color: #555555;
                                width: 72px;
                                horizontal-alignment: right;
                            }
                        }
                    }
                }
            }

            // Divider
            Rectangle { height: 1px; background: #3c3c3c; }

            // Browse button
            Button {
                text: "Browse Filesystem…";
                clicked => { root.browse-requested(); }
            }

            // Cancel
            HorizontalLayout {
                alignment: end;
                Button {
                    text: "Cancel";
                    clicked => { root.cancelled(); }
                }
            }
        }
    }
}
