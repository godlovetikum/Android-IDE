// android-ide/ui/components/file_tree.slint
//
// File tree explorer widget (task 016).
//
// Renders a flat list of FileTreeEntry items. Each entry carries its depth
// level so the Rust side builds the list with correct indentation — Slint's
// ListView is flat so we represent the tree as a flat pre-order traversal
// where collapsed nodes have their descendants removed from the model.
//
// The Rust side is responsible for building and mutating the model when the
// user expands or collapses directories.

export struct FileTreeEntry {
    name: string,
    path: string,
    is-directory: bool,
    is-expanded: bool,
    is-selected: bool,
    depth: int,
    has-children: bool,  // false for empty dirs / files
}

export component FileTree inherits Rectangle {
    background: #252526;

    in-out property <[FileTreeEntry]> entries;

    // Emitted when the user taps a file (not a directory)
    callback file-opened(string /*path*/);

    // Emitted when the user taps a directory row — Rust toggles expand/collapse
    // and updates the model
    callback directory-toggled(string /*path*/, bool /*currently-expanded*/);

    // Emitted on long-press or right-click — Rust shows a context menu
    callback context-menu-requested(string /*path*/, bool /*is-directory*/);

    // Scrollable list
    ListView {
        for entry in entries : row := Rectangle {
            height: 28px;
            background: entry.is-selected ? #094771
                       : row-touch.has-hover ? #2a2d2e
                       : transparent;

            row-touch := TouchArea {
                pointer-event(event) => {
                    if event.kind == PointerEventKind.up && event.button == PointerEventButton.right {
                        root.context-menu-requested(entry.path, entry.is-directory);
                    }
                }
                clicked => {
                    if entry.is-directory {
                        root.directory-toggled(entry.path, entry.is-expanded);
                    } else {
                        root.file-opened(entry.path);
                    }
                }
            }

            HorizontalLayout {
                // Indentation: 16px per depth level + 4px base margin
                padding-left: 4px + entry.depth * 16px;
                spacing: 4px;
                alignment: center;

                // Chevron (only for directories)
                Text {
                    width: 14px;
                    text: entry.is-directory
                          ? (entry.is-expanded ? "▾" : "▸")
                          : "";
                    font-size: 10px;
                    color: #666666;
                    vertical-alignment: center;
                }

                // File / folder icon
                Text {
                    width: 16px;
                    text: entry.is-directory
                          ? (entry.is-expanded ? "📂" : "📁")
                          : file-icon(entry.name);
                    font-size: 13px;
                    vertical-alignment: center;
                }

                // Name
                Text {
                    text: entry.name;
                    font-size: 13px;
                    color: entry.is-directory ? #cccccc : #d4d4d4;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
            }
        }
    }

    // Returns a suitable icon character for a file based on its extension.
    pure function file-icon(name: string) -> string {
        // Slint doesn't have substring matching, so we delegate icon logic to
        // the entry model itself in a future enhancement. For now, use a
        // neutral document icon for all files.
        "📄"
    }
}

// ---------------------------------------------------------------------------
// Sidebar container — wraps the file tree with a header bar
// ---------------------------------------------------------------------------

export component Sidebar inherits Rectangle {
    background: #252526;
    min-width: 180px;
    preferred-width: 240px;
    max-width: 320px;

    in-out property <[FileTreeEntry]> entries <=> tree.entries;
    in property <string> project-name: "No project open";

    callback file-opened(string) <=> tree.file-opened;
    callback directory-toggled(string, bool) <=> tree.directory-toggled;
    callback context-menu-requested(string, bool) <=> tree.context-menu-requested;

    // "New project" / "Open project" buttons
    callback new-project-requested();
    callback open-project-requested();

    VerticalLayout {
        spacing: 0;

        // Header
        Rectangle {
            height: 36px;
            background: #252526;
            border-bottom: 1px;
            border-color: #3c3c3c;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                spacing: 4px;
                alignment: center;

                Text {
                    text: "EXPLORER";
                    font-size: 11px;
                    font-weight: 700;
                    color: #bbbbbb;
                    letter-spacing: 1px;
                    horizontal-stretch: 1;
                }

                // New file (will trigger new-project-requested for now;
                // task 019 adds per-file creation)
                new-btn := TouchArea {
                    width: 24px; height: 24px;
                    clicked => { root.new-project-requested(); }
                    Rectangle {
                        border-radius: 4px;
                        background: new-btn.has-hover ? #3c3c3c : transparent;
                        Text {
                            text: "+";
                            color: #cccccc;
                            font-size: 18px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                open-btn := TouchArea {
                    width: 24px; height: 24px;
                    clicked => { root.open-project-requested(); }
                    Rectangle {
                        border-radius: 4px;
                        background: open-btn.has-hover ? #3c3c3c : transparent;
                        Text {
                            text: "⊞";
                            color: #cccccc;
                            font-size: 16px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // Project name sub-header
        Rectangle {
            height: 28px;
            background: #252526;

            HorizontalLayout {
                padding-left: 12px;
                alignment: center;
                Text {
                    text: project-name;
                    font-size: 11px;
                    font-weight: 700;
                    color: #cccccc;
                    overflow: elide;
                }
            }
        }

        // Tree — takes remaining height
        tree := FileTree {
            vertical-stretch: 1;
        }
    }
}
