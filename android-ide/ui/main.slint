// android-ide/ui/main.slint
//
// Main application window for the Android IDE.
//
// Layout:
//   ┌──────────────────────────────────────────┐
//   │ AppBar: [≡] project-name          [⋮]   │
//   ├──────────┬───────────────────────────────┤
//   │ Sidebar  │ TabBar [tab×] [tab×] [tab×]  │
//   │ FileTree │───────────────────────────────│
//   │          │ Editor area (Monaco WebView)  │
//   ├──────────┴───────────────────────────────┤
//   │ StatusBar: ⎇branch | file | Ln,Col | lang│
//   └──────────────────────────────────────────┘

import { Sidebar, FileTreeEntry }    from "components/file_tree.slint";
import { NewProjectDialog, NewProjectRequest, OpenProjectDialog, RecentProject } from "components/dialogs.slint";

export { FileTreeEntry, NewProjectRequest, RecentProject }

/// A single open editor tab — mirrors EditorTab in modules/editor/src/tab.rs
export struct TabEntry {
    id:        string,
    name:      string,
    path:      string,
    is-active: bool,
    is-dirty:  bool,
    language:  string,
}

export component MainWindow inherits Window {
    title: "AndroidIDE";
    background: #1e1e1e;
    preferred-width: 960px;
    preferred-height: 600px;
    min-width: 320px;
    min-height: 400px;

    // -------------------------------------------------------------------------
    // Public properties — set by Rust
    // -------------------------------------------------------------------------

    in-out property <string> project-name: "";
    in-out property <bool>   sidebar-visible: true;
    in-out property <[FileTreeEntry]> file-tree-entries;
    in-out property <[RecentProject]> recent-projects;

    // Open tabs model
    in-out property <[TabEntry]> open-tabs;

    // Active tab / status bar (kept as scalars for quick binding)
    in-out property <string> active-file-path: "";
    in-out property <string> active-language:  "";
    in-out property <int>    cursor-line:       1;
    in-out property <int>    cursor-col:        1;
    in-out property <string> git-branch:        "";
    in-out property <bool>   has-unsaved-changes: false;

    // Dialog visibility
    in-out property <bool> show-new-project-dialog:  false;
    in-out property <bool> show-open-project-dialog: false;

    // -------------------------------------------------------------------------
    // Callbacks — implemented by Rust (src/ui.rs)
    // -------------------------------------------------------------------------

    // File tree
    callback file-opened(string /*path*/);
    callback directory-toggled(string /*path*/, bool /*was-expanded*/);
    callback context-menu-requested(string /*path*/, bool /*is-directory*/);

    // Tab management (task 018)
    callback tab-switch-requested(string /*tab-id*/);
    callback tab-close-requested(string /*tab-id*/);

    // Project lifecycle
    callback new-project-confirmed(NewProjectRequest);
    callback open-project-confirmed(string /*path*/);
    callback saf-browse-requested();

    // Menu bar
    callback menu-toggle-sidebar();
    callback menu-overflow-tapped();

    // -------------------------------------------------------------------------
    // Derived
    // -------------------------------------------------------------------------

    property <bool> has-project: project-name != "";
    property <bool> narrow: root.width < 600px;

    // -------------------------------------------------------------------------
    // Layout
    // -------------------------------------------------------------------------

    VerticalLayout {
        spacing: 0;

        // ── App Bar ──────────────────────────────────────────────────────────
        app-bar := Rectangle {
            height: 48px;
            background: #333333;
            drop-shadow-blur: 4px;
            drop-shadow-color: #00000066;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                alignment: center;

                hamburger := TouchArea {
                    width: 40px; height: 40px;
                    clicked => { root.menu-toggle-sidebar(); }
                    Rectangle {
                        border-radius: 20px;
                        background: hamburger.has-hover ? #ffffff18 : transparent;
                        Text {
                            text: "☰";
                            font-size: 20px;
                            color: #cccccc;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Text {
                    text: root.has-project ? project-name : "AndroidIDE";
                    font-size: 15px;
                    font-weight: 600;
                    color: #cccccc;
                    horizontal-stretch: 1;
                    overflow: elide;
                }

                if root.has-unsaved-changes : Rectangle {
                    width: 8px; height: 8px;
                    border-radius: 4px;
                    background: #e5c07b;
                }

                overflow-btn := TouchArea {
                    width: 40px; height: 40px;
                    clicked => { root.menu-overflow-tapped(); }
                    Rectangle {
                        border-radius: 20px;
                        background: overflow-btn.has-hover ? #ffffff18 : transparent;
                        Text {
                            text: "⋮";
                            font-size: 22px;
                            color: #cccccc;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ── Main area (sidebar + editor) ─────────────────────────────────────
        Rectangle {
            vertical-stretch: 1;

            HorizontalLayout {
                spacing: 0;

                if root.sidebar-visible || !root.narrow : sidebar := Sidebar {
                    width: root.narrow ? min(root.width * 0.8, 280px) : 240px;
                    entries <=> root.file-tree-entries;
                    project-name: root.project-name != "" ? root.project-name : "No project open";

                    file-opened(path)                     => { root.file-opened(path); }
                    directory-toggled(path, expanded)     => { root.directory-toggled(path, expanded); }
                    context-menu-requested(path, is-dir)  => { root.context-menu-requested(path, is-dir); }
                    new-project-requested                 => { root.show-new-project-dialog = true; }
                    open-project-requested                => { root.show-open-project-dialog = true; }
                }

                if root.sidebar-visible || !root.narrow : Rectangle {
                    width: 1px;
                    background: #3c3c3c;
                }

                // Editor column
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 0;

                    // ── Tab bar ───────────────────────────────────────────────
                    if open-tabs.length > 0 : tab-bar := Rectangle {
                        height: 35px;
                        background: #2d2d2d;
                        clip: true;

                        HorizontalLayout {
                            spacing: 0;
                            alignment: start;

                            for tab[_i] in root.open-tabs : tab-chip := Rectangle {
                                height: 35px;
                                width: min(chip-label.preferred-width + 52px, 200px);
                                background: tab.is-active ? #1e1e1e : #2d2d2d;
                                border-top: 2px;
                                border-color: tab.is-active ? #007acc : transparent;

                                // Highlight on hover
                                property <bool> hovered: chip-touch.has-hover || close-touch.has-hover;

                                // Tab click area — switch to this tab
                                chip-touch := TouchArea {
                                    x: 0; y: 0;
                                    width: parent.width - 28px;
                                    height: parent.height;
                                    clicked => { root.tab-switch-requested(tab.id); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 4px;
                                    spacing: 4px;
                                    alignment: center;

                                    // Dirty dot OR filename
                                    chip-label := Text {
                                        text: tab.name;
                                        font-size: 13px;
                                        color: tab.is-active ? #ffffff : #cccccc;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }

                                    // Dirty indicator
                                    if tab.is-dirty : Rectangle {
                                        width: 6px; height: 6px;
                                        border-radius: 3px;
                                        background: #cccccc;
                                    }

                                    // Close button
                                    close-btn := Rectangle {
                                        width: 20px; height: 20px;
                                        border-radius: 4px;
                                        background: close-touch.has-hover ? #ffffff28 : transparent;

                                        close-touch := TouchArea {
                                            width: 20px; height: 20px;
                                            clicked => { root.tab-close-requested(tab.id); }
                                        }

                                        Text {
                                            text: "×";
                                            font-size: 14px;
                                            color: close-touch.has-hover ? #ffffff : #888888;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Bottom border for inactive tabs
                                if !tab.is-active : Rectangle {
                                    y: parent.height - 1px;
                                    height: 1px;
                                    background: #3c3c3c;
                                }
                            }

                            // Right-side fill
                            Rectangle {
                                horizontal-stretch: 1;
                                background: #2d2d2d;
                                border-bottom: 1px;
                                border-color: #3c3c3c;
                            }
                        }
                    }

                    // ── Editor container ─────────────────────────────────────
                    editor-container := Rectangle {
                        vertical-stretch: 1;
                        background: #1e1e1e;
                        clip: true;

                        // Welcome screen — no project open
                        if !root.has-project : VerticalLayout {
                            alignment: center;
                            spacing: 24px;

                            Text {
                                text: "AndroidIDE";
                                font-size: 32px;
                                font-weight: 700;
                                color: #3c3c3c;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: "A VS Code-style IDE for Android";
                                font-size: 14px;
                                color: #555555;
                                horizontal-alignment: center;
                            }

                            HorizontalLayout {
                                alignment: center;
                                spacing: 16px;

                                new-btn := Rectangle {
                                    width: 160px; height: 44px;
                                    border-radius: 6px;
                                    background: new-btn-touch.has-hover ? #005f9e : #007acc;
                                    new-btn-touch := TouchArea {
                                        clicked => { root.show-new-project-dialog = true; }
                                    }
                                    Text {
                                        text: "New Project";
                                        font-size: 14px;
                                        color: #ffffff;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                open-btn := Rectangle {
                                    width: 160px; height: 44px;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: #3c3c3c;
                                    background: open-btn-touch.has-hover ? #2d2d2d : transparent;
                                    open-btn-touch := TouchArea {
                                        clicked => { root.show-open-project-dialog = true; }
                                    }
                                    Text {
                                        text: "Open Project";
                                        font-size: 14px;
                                        color: #cccccc;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // Hint when project open but no file selected
                        if root.has-project && root.open-tabs.length == 0 : Text {
                            text: "Select a file from the explorer to open it";
                            font-size: 14px;
                            color: #3c3c3c;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ── Status Bar ───────────────────────────────────────────────────────
        Rectangle {
            height: 22px;
            background: #007acc;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;
                alignment: center;

                if root.git-branch != "" : HorizontalLayout {
                    spacing: 4px;
                    alignment: center;
                    Text { text: "⎇"; font-size: 11px; color: #ffffffcc; }
                    Text { text: root.git-branch; font-size: 11px; color: #ffffffcc; }
                }

                Rectangle { horizontal-stretch: 1; }

                if root.active-file-path != "" : Text {
                    text: root.active-file-path;
                    font-size: 11px;
                    color: #ffffffcc;
                }

                if root.active-file-path != "" : Text {
                    text: "Ln " + root.cursor-line + ", Col " + root.cursor-col;
                    font-size: 11px;
                    color: #ffffffcc;
                }

                if root.active-language != "" : Text {
                    text: root.active-language;
                    font-size: 11px;
                    color: #ffffffcc;
                }
            }
        }
    }

    // ── Dialogs ───────────────────────────────────────────────────────────────

    if root.show-new-project-dialog : NewProjectDialog {
        width: 100%; height: 100%;
        project-types: ["Rust", "Kotlin (Android)", "Python", "C/C++", "Generic"];
        confirmed(req) => {
            root.show-new-project-dialog = false;
            root.new-project-confirmed(req);
        }
        cancelled    => { root.show-new-project-dialog = false; }
        browse-requested => { root.saf-browse-requested(); }
    }

    if root.show-open-project-dialog : OpenProjectDialog {
        width: 100%; height: 100%;
        recent-projects: root.recent-projects;
        project-selected(path) => {
            root.show-open-project-dialog = false;
            root.open-project-confirmed(path);
        }
        browse-requested => {
            root.show-open-project-dialog = false;
            root.saf-browse-requested();
        }
        cancelled => { root.show-open-project-dialog = false; }
    }
}
