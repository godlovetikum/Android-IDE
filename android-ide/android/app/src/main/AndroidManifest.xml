<?xml version="1.0" encoding="utf-8"?>
<!--
    android-ide/android/app/src/main/AndroidManifest.xml

    Migration note (2026-06-12):
      Replaced dev.androidide.IDEActivity (NativeActivity subclass, Slint-specific)
      with dev.androidide.MainActivity (ComponentActivity, Kotlin/Jetpack Compose).
      Removed android.app.lib_name meta-data (Rust .so NativeActivity lookup).
      All other settings (permissions, configChanges, icons, SDK versions) unchanged.

    Activity model:
      MainActivity extends ComponentActivity. Jetpack Compose renders the full
      IDE UI natively — no native Surface, no WebView overlay positioning needed.
      The Monaco editor WebView is embedded directly as a Compose AndroidView.

    Storage permission strategy (unchanged from prior implementation):
      API 26–28: READ + WRITE external storage required (scoped storage not yet
                 available). Both declared with maxSdkVersion to cap exposure.
      API 29+:   SAF (Intent.ACTION_OPEN_DOCUMENT_TREE) grants access without
                 manifest permissions. No changes needed for API 29+.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Available for future network features (LSP, remote AI, extension registry). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- API 26–32: required for std file access outside internal storage. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- API 26–28: required to write files on external storage. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:label="Android IDE"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:hardwareAccelerated="true">

        <!--
            MainActivity — Kotlin/Jetpack Compose entry point.

            configChanges: handled in onConfigurationChanged() so the Activity
              is not recreated on orientation change. Compose re-measures and
              re-lays out automatically; the ViewModel retains state.

            android:exported="true": required for the LAUNCHER intent filter.
        -->
        <activity
            android:name="dev.androidide.MainActivity"
            android:label="Android IDE"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|uiMode|density">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
